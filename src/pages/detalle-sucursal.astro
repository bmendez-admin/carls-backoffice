---
export const prerender = true;
import Layout from "../layouts/layout.astro";
---

<Layout title="Detalle Sucursal">
    <div id="auth-check" style="display:none">
        <div class="card">
            <div class="section-header">
                <div style="display:flex;align-items:center;gap:12px;">
                    <a href="/sucursales" class="back-btn">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <polyline points="15 18 9 12 15 6"></polyline>
                        </svg>
                        Regresar
                    </a>
                    <h2 id="sucursal-titulo">Cargando...</h2>
                </div>
                <div class="header-actions">
                    <button id="btn-agregar-plantilla" class="btn-primary"
                        >+ Agregar Plantilla</button
                    >
                </div>
            </div>

            <div
                id="plantillas-container"
                style="padding:24px;display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:20px;"
            >
                <div class="loading-cell">Cargando plantillas...</div>
            </div>
        </div>
    </div>

    <div
        id="modal-agregar"
        style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:500;align-items:center;justify-content:center;"
    >
        <div
            style="background:white;border-radius:8px;width:420px;box-shadow:0 8px 32px rgba(0,0,0,0.18);overflow:hidden;"
        >
            <div class="section-header">
                <h2>Agregar Plantilla</h2>
                <button
                    id="modal-agregar-close"
                    style="background:none;border:none;color:white;font-size:18px;cursor:pointer;"
                    >✕</button
                >
            </div>
            <div
                style="padding:20px;display:flex;flex-direction:column;gap:12px;"
            >
                <p style="font-size:13px;color:var(--text-muted);">
                    Selecciona las plantillas que deseas agregar a esta
                    sucursal.
                </p>
                <div
                    id="plantillas-disponibles"
                    style="display:flex;flex-direction:column;gap:8px;"
                >
                </div>
                <div
                    style="display:flex;justify-content:flex-end;gap:8px;margin-top:8px;"
                >
                    <button
                        id="modal-agregar-cancel"
                        style="background:none;border:1px solid var(--border-gray);border-radius:4px;padding:7px 16px;font-size:13px;cursor:pointer;"
                        >Cancelar</button
                    >
                    <button id="modal-agregar-save" class="btn-primary"
                        >Agregar</button
                    >
                </div>
            </div>
        </div>
    </div>

    <div
        id="modal-confirmar"
        style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:500;align-items:center;justify-content:center;"
    >
        <div
            style="background:white;border-radius:8px;width:380px;box-shadow:0 8px 32px rgba(0,0,0,0.18);overflow:hidden;"
        >
            <div class="section-header" style="background:#c41520;">
                <h2>Quitar Plantilla</h2>
                <button
                    id="modal-confirmar-close"
                    style="background:none;border:none;color:white;font-size:18px;cursor:pointer;"
                    >✕</button
                >
            </div>
            <div
                style="padding:20px;display:flex;flex-direction:column;gap:16px;"
            >
                <p
                    id="modal-confirmar-texto"
                    style="font-size:13px;color:var(--text-dark);"
                >
                </p>
                <div style="display:flex;justify-content:flex-end;gap:8px;">
                    <button
                        id="modal-confirmar-cancel"
                        style="background:none;border:1px solid var(--border-gray);border-radius:4px;padding:7px 16px;font-size:13px;cursor:pointer;"
                        >Cancelar</button
                    >
                    <button
                        id="modal-confirmar-ok"
                        style="background:#c41520;color:white;border:none;border-radius:4px;padding:7px 16px;font-size:13px;font-weight:700;cursor:pointer;"
                        >Quitar</button
                    >
                </div>
            </div>
        </div>
    </div>

    <div id="toast" style="display:none"></div>
</Layout>

<script>
    import { createClient } from "@supabase/supabase-js";

    const db = createClient(
        "https://gbklqpbcllhdixiuxwzt.supabase.co",
        "sb_publishable_478TOeFf5POv09rZ58BeyQ_BA8rY8cf",
    );

    const PLAYER_BASE =
        "https://bmendez-admin.github.io/digital-signage-player/";
    const params = new URLSearchParams(window.location.search);
    const sucursalSlug = params.get("sucursal");

    let sucursalId = null;
    let sucursalNombre = null;
    let plantillasAsignadas = [];
    let todasLasPlantillas = [];
    let plantillaParaQuitar = null;

    function showToast(msg, type = "success") {
        const t = document.getElementById("toast");
        t.textContent = msg;
        t.className = `toast ${type}`;
        t.style.display = "block";
        setTimeout(() => {
            t.style.display = "none";
        }, 3000);
    }

    function openModal(id) {
        document.getElementById(id).style.display = "flex";
    }

    function closeModal(id) {
        document.getElementById(id).style.display = "none";
    }

    async function init() {
        const { data: session } = await db.auth.getSession();
        if (!session.session) {
            window.location.href = "/";
            return;
        }
        document.getElementById("auth-check").style.display = "block";

        if (!sucursalSlug) {
            window.location.href = "/sucursales";
            return;
        }

        const { data: suc } = await db
            .from("sucursales")
            .select("id, nombre")
            .eq("slug", sucursalSlug)
            .single();
        if (!suc) {
            window.location.href = "/sucursales";
            return;
        }

        sucursalId = suc.id;
        sucursalNombre = suc.nombre;
        document.getElementById("sucursal-titulo").textContent = suc.nombre;

        const { data: todas } = await db
            .from("plantillas")
            .select("id, nombre, slug")
            .order("nombre");
        todasLasPlantillas = todas || [];

        await loadPlantillas();
    }

    async function loadPlantillas() {
        const { data: sp } = await db
            .from("sucursal_plantillas")
            .select("plantilla_id, plantillas(id, nombre, slug, descripcion)")
            .eq("sucursal_id", sucursalId);

        plantillasAsignadas = sp || [];
        renderPlantillas();
    }

    function renderPlantillas() {
        const container = document.getElementById("plantillas-container");

        if (!plantillasAsignadas.length) {
            container.innerHTML =
                '<p style="color:var(--text-muted);font-size:13px;font-style:italic;padding:20px;">Esta sucursal no tiene plantillas asignadas.</p>';
            return;
        }

        container.innerHTML = plantillasAsignadas
            .map((sp) => {
                const p = sp.plantillas;
                const url = `${PLAYER_BASE}?sucursal=${sucursalSlug}&plantilla=${p.slug}`;
                return `
      <div style="background:white;border:1px solid var(--border-gray);border-radius:10px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);transition:box-shadow 0.2s;">
        <div style="background:var(--carls-red);padding:16px 20px;display:flex;align-items:center;justify-content:space-between;">
          <div style="display:flex;flex-direction:column;gap:4px;">
            <span style="color:white;font-size:15px;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;">${p.nombre}</span>
            <code style="font-size:11px;color:rgba(255,255,255,0.7);background:rgba(0,0,0,0.15);padding:2px 8px;border-radius:3px;width:fit-content;">${p.slug}</code>
          </div>
          <button class="btn-quitar" data-id="${p.id}" data-nombre="${p.nombre}" style="background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);color:white;border-radius:6px;padding:6px 14px;font-size:12px;font-weight:700;cursor:pointer;letter-spacing:0.04em;transition:background 0.15s;">✕ Quitar</button>
        </div>
        <div style="padding:20px;display:flex;flex-direction:column;gap:14px;">
          ${p.descripcion ? `<p style="font-size:13px;color:var(--text-muted);font-style:italic;line-height:1.4;">${p.descripcion}</p>` : ""}
          <div style="background:#f8f8f8;border-radius:6px;padding:10px 14px;display:flex;align-items:center;gap:8px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            <span style="font-size:11px;color:var(--text-muted);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${url}</span>
            <button class="btn-copiar" data-url="${url}" style="background:none;border:none;color:var(--carls-red);font-size:11px;font-weight:700;cursor:pointer;padding:0;white-space:nowrap;">Copiar</button>
          </div>
          <a href="/precios?sucursal=${sucursalSlug}&plantilla=${p.slug}" style="display:block;text-align:center;background:var(--carls-red);color:white;border-radius:6px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;letter-spacing:0.04em;transition:background 0.15s;">Editar Precios</a>
        </div>
      </div>
    `;
            })
            .join("");

        document.querySelectorAll(".btn-quitar").forEach((btn) => {
            btn.addEventListener("click", () => {
                plantillaParaQuitar = btn.dataset.id;
                document.getElementById("modal-confirmar-texto").textContent =
                    `¿Seguro que quieres quitar la plantilla "${btn.dataset.nombre}" de ${sucursalNombre}? Se eliminarán todos sus precios en esta sucursal.`;
                openModal("modal-confirmar");
            });
        });

        document.querySelectorAll(".btn-copiar").forEach((btn) => {
            btn.addEventListener("click", () => {
                navigator.clipboard.writeText(btn.dataset.url);
                showToast("URL copiada al portapapeles");
            });
        });
    }

    function renderModalAgregar() {
        const asignadasIds = plantillasAsignadas.map((sp) => sp.plantilla_id);
        const disponibles = todasLasPlantillas.filter(
            (p) => !asignadasIds.includes(p.id),
        );
        const container = document.getElementById("plantillas-disponibles");

        if (!disponibles.length) {
            container.innerHTML =
                '<p style="font-size:13px;color:var(--text-muted);font-style:italic;">Todas las plantillas ya están asignadas.</p>';
            return;
        }

        container.innerHTML = disponibles
            .map(
                (p) => `
      <label style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid var(--border-gray);border-radius:6px;cursor:pointer;transition:border-color 0.15s;">
        <input type="checkbox" value="${p.id}" style="width:16px;height:16px;accent-color:var(--carls-red);" />
        <div>
          <div style="font-size:13px;font-weight:700;color:var(--text-dark);">${p.nombre}</div>
          <div style="font-size:11px;color:var(--text-muted);">${p.slug}</div>
        </div>
      </label>
    `,
            )
            .join("");
    }

    async function agregarPlantillas() {
        const checks = document.querySelectorAll(
            '#plantillas-disponibles input[type="checkbox"]:checked',
        );
        if (!checks.length) {
            showToast("Selecciona al menos una plantilla", "error");
            return;
        }

        const btn = document.getElementById("modal-agregar-save");
        btn.textContent = "Agregando...";
        btn.disabled = true;

        for (const check of checks) {
            const plantillaId = check.value;

            await db.from("sucursal_plantillas").insert({
                sucursal_id: sucursalId,
                plantilla_id: plantillaId,
                activa: true,
            });

            const { data: productos } = await db
                .from("productos")
                .select("id")
                .eq("plantilla_id", plantillaId);

            if (productos && productos.length) {
                const preciosInsert = productos.map((p) => ({
                    producto_id: p.id,
                    sucursal_id: sucursalId,
                    burger: null,
                    doble: null,
                    combo: null,
                    combo_doble: null,
                }));
                await db.from("precios").insert(preciosInsert);
            }

            const { data: upgrades } = await db
                .from("upgrades")
                .select("nombre, precio, orden")
                .eq("plantilla_id", plantillaId)
                .limit(1);

            if (upgrades && upgrades.length) {
                const { data: upgradesBase } = await db
                    .from("upgrades")
                    .select("nombre, precio, orden")
                    .eq("plantilla_id", plantillaId);

                const upgradesInsert = upgradesBase.map((u) => ({
                    plantilla_id: plantillaId,
                    sucursal_id: sucursalId,
                    nombre: u.nombre,
                    precio: u.precio,
                    orden: u.orden,
                }));
                await db.from("upgrades").insert(upgradesInsert);
            }
        }

        closeModal("modal-agregar");
        await loadPlantillas();
        showToast("Plantillas agregadas correctamente");
        btn.textContent = "Agregar";
        btn.disabled = false;
    }

    async function quitarPlantilla() {
        if (!plantillaParaQuitar) return;

        const btn = document.getElementById("modal-confirmar-ok");
        btn.textContent = "Quitando...";
        btn.disabled = true;

        const { data: productos } = await db
            .from("productos")
            .select("id")
            .eq("plantilla_id", plantillaParaQuitar);

        if (productos && productos.length) {
            const ids = productos.map((p) => p.id);
            await db
                .from("precios")
                .delete()
                .eq("sucursal_id", sucursalId)
                .in("producto_id", ids);
        }

        await db
            .from("upgrades")
            .delete()
            .eq("sucursal_id", sucursalId)
            .eq("plantilla_id", plantillaParaQuitar);
        await db
            .from("sucursal_plantillas")
            .delete()
            .eq("sucursal_id", sucursalId)
            .eq("plantilla_id", plantillaParaQuitar);

        plantillaParaQuitar = null;
        closeModal("modal-confirmar");
        await loadPlantillas();
        showToast("Plantilla quitada correctamente");
        btn.textContent = "Quitar";
        btn.disabled = false;
    }

    document
        .getElementById("btn-agregar-plantilla")
        .addEventListener("click", () => {
            renderModalAgregar();
            openModal("modal-agregar");
        });

    document
        .getElementById("modal-agregar-save")
        .addEventListener("click", agregarPlantillas);
    document
        .getElementById("modal-agregar-cancel")
        .addEventListener("click", () => closeModal("modal-agregar"));
    document
        .getElementById("modal-agregar-close")
        .addEventListener("click", () => closeModal("modal-agregar"));
    document
        .getElementById("modal-confirmar-ok")
        .addEventListener("click", quitarPlantilla);
    document
        .getElementById("modal-confirmar-cancel")
        .addEventListener("click", () => closeModal("modal-confirmar"));
    document
        .getElementById("modal-confirmar-close")
        .addEventListener("click", () => closeModal("modal-confirmar"));

    init();
</script>

---
export const prerender = true
import Layout from '../layouts/layout.astro'
---
<Layout title="Dashboard">
  <div id="auth-check" style="display:none">
    <div class="card">
      <div class="section-header">
        <h2>Carl's Jr. Backoffice</h2>
      </div>
      <div class="nav-cards-list">
        <a href="/sucursales" class="nav-card">
          <span class="nav-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </span>
          <span>Sucursales</span>
        </a>
        <a href="/plantillas" class="nav-card">
          <span class="nav-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="9" y1="21" x2="9" y2="9"/>
            </svg>
          </span>
          <span>Plantillas</span>
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js'
  const db = createClient(
    'https://gbklqpbcllhdixiuxwzt.supabase.co',
    'sb_publishable_478TOeFf5POv09rZ58BeyQ_BA8rY8cf'
  )
  async function init() {
    const { data } = await db.auth.getSession()
    if (!data.session) { window.location.href = '/'; return }
    document.getElementById('auth-check').style.display = 'block'
  }
  init()
</script>

<style>
.nav-cards-list {
  display: flex;
  flex-direction: row;
  gap: 0;
}

.nav-card {
  background: white;
  padding: 18px 24px;
  display: flex;
  align-items: center;
  gap: 14px;
  cursor: pointer;
  text-decoration: none;
  color: var(--text-dark);
  border-right: 1px solid var(--border-gray);
  transition: background 0.15s;
  flex: 1;
}

.nav-card:last-child {
  border-right: none;
}

.nav-card:hover {
  background: #fafafa;
}

.nav-card-icon {
  color: var(--carls-red);
  display: flex;
  align-items: center;
}

.nav-card span:last-child {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
}
</style>
camposConDatos = TODOS_CAMPOS.filter(campo =>
  productos.some(p => {
    const precio = p.precios.find(pr => pr.sucursal_id === sucursalId);
    return precio && precio[campo] !== null;
  })
);

if (camposConDatos.length === 0) {
  camposConDatos = [...TODOS_CAMPOS];
}

tbody.innerHTML = productos.map(p => {
  const precio = p.precios.find(pr => pr.sucursal_id === sucursalId) || {};
  const celdas = TODOS_CAMPOS.map(campo => {
    const activo = camposConDatos.includes(campo);
    const val = precio[campo];
    if (!activo) {
      return `<td><input type="number" disabled placeholder="—" style="width:90px;text-align:right;background:#f0f0f0;color:#bbb;border:1px solid #e0e0e0;border-radius:4px;padding:5px 8px;cursor:not-allowed;" /></td>`;
    }
    return `<td>
      <input type="number"
        class="price-input"
        data-producto="${p.id}"
        data-precio-id="${precio.id || ""}"
        data-field="${campo}"
        value="${val !== null && val !== undefined ? val : ""}"
        placeholder="—"
        step="0.01"
        min="0"
        style="width:90px;text-align:right;"
      />
    </td>`;
  }).join("");

  return `<tr>
    <td style="color:var(--text-muted);font-weight:700;">${p.numero}</td>
    <td>
      <strong>${p.nombre}</strong>
      <div style="font-size:11px;color:var(--text-muted);font-style:italic;">${p.subtitulo || ""}</div>
    </td>
    ${celdas}
  </tr>`;
}).join("");

document.querySelectorAll(".price-input").forEach(input => {
  input.addEventListener("input", e => {
    const productoId = e.target.dataset.producto;
    const field = e.target.dataset.field;
    const val = e.target.value === "" ? null : parseFloat(e.target.value);
    if (!pendingChanges[productoId]) pendingChanges[productoId] = {};
    pendingChanges[productoId][field] = val;
    e.target.style.borderColor = "var(--carls-yellow)";
    e.target.style.background = "#fffbf0";
  });
});

document.getElementById("global-changer").style.display = "flex";

await loadUpgrades();
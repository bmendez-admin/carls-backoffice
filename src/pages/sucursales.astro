---
export const prerender = true
import Layout from '../layouts/layout.astro'
---
<Layout title="Sucursales">
  <div id="auth-check" style="display:none">
    <div class="card">
      <div class="section-header">
        <h2>Sucursales</h2>
        <div class="header-actions">
          <a href="/dashboard" class="back-btn" title="Regresar">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            Regresar
          </a>
        </div>
      </div>

      <div class="filters-bar">
        <div class="filter-search">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input type="text" id="search" placeholder="Buscar por nombre o slug..." />
          <button id="clear-search" class="clear-btn" title="Limpiar">✕</button>
        </div>

        <div class="filter-group">
          <label>Estado</label>
          <select id="filter-estado">
            <option value="">Todos</option>
            <option value="activa">Activa</option>
            <option value="inactiva">Inactiva</option>
          </select>
        </div>

        <div class="filter-group">
          <label>Plantilla</label>
          <select id="filter-plantilla">
            <option value="">Todas</option>
          </select>
        </div>

        <button id="clear-filters" class="clear-filters-btn">
          Limpiar filtros
        </button>
      </div>

      <div class="results-bar">
        <span id="results-count" class="results-count"></span>
      </div>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Slug</th>
              <th>Plantillas</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody id="sucursales-body">
            <tr><td colspan="5" class="loading-cell">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js'

  const db = createClient(
    'https://gbklqpbcllhdixiuxwzt.supabase.co',
    'sb_publishable_478TOeFf5POv09rZ58BeyQ_BA8rY8cf'
  )

  let allData = []

  async function init() {
    const { data: session } = await db.auth.getSession()
    if (!session.session) { window.location.href = '/'; return }
    document.getElementById('auth-check').style.display = 'block'
    await loadSucursales()
  }

  async function loadSucursales() {
    const { data, error } = await db
      .from('sucursales')
      .select('*, sucursal_plantillas(plantilla_id, plantillas(id, nombre))')
      .order('nombre')

    if (error || !data) {
      document.getElementById('sucursales-body').innerHTML =
        '<tr><td colspan="5" class="loading-cell">Error al cargar datos.</td></tr>'
      return
    }

    allData = data
    populatePlantillaFilter(data)
    applyFilters()
  }

  function populatePlantillaFilter(data) {
    const select = document.getElementById('filter-plantilla')
    const nombres = new Set()
    data.forEach(s => {
      s.sucursal_plantillas.forEach(sp => {
        if (sp.plantillas?.nombre) nombres.add(sp.plantillas.nombre)
      })
    })
    nombres.forEach(nombre => {
      const opt = document.createElement('option')
      opt.value = nombre
      opt.textContent = nombre
      select.appendChild(opt)
    })
  }

  function applyFilters() {
    const q = document.getElementById('search').value.toLowerCase()
    const estado = document.getElementById('filter-estado').value
    const plantilla = document.getElementById('filter-plantilla').value

    let filtered = allData.filter(s => {
      const matchSearch = !q ||
        s.nombre.toLowerCase().includes(q) ||
        s.slug.toLowerCase().includes(q)

      const matchEstado = !estado ||
        (estado === 'activa' && s.activa) ||
        (estado === 'inactiva' && !s.activa)

      const matchPlantilla = !plantilla ||
        s.sucursal_plantillas.some(sp => sp.plantillas?.nombre === plantilla)

      return matchSearch && matchEstado && matchPlantilla
    })

    renderTable(filtered)
  }

  function renderTable(data) {
    const tbody = document.getElementById('sucursales-body')
    const count = document.getElementById('results-count')
    count.textContent = `${data.length} resultado${data.length !== 1 ? 's' : ''}`

    if (!data.length) {
      tbody.innerHTML = '<tr><td colspan="5" class="loading-cell">No se encontraron sucursales con los filtros aplicados.</td></tr>'
      return
    }

    tbody.innerHTML = data.map(s => {
      const plantillas = s.sucursal_plantillas
        .map(sp => sp.plantillas?.nombre)
        .filter(Boolean)
        .join(', ') || '—'

      return `<tr>
        <td><strong>${s.nombre}</strong></td>
        <td><code>${s.slug}</code></td>
        <td>${plantillas}</td>
        <td>
          <span class="status-badge ${s.activa ? 'active' : 'inactive'}"></span>
          ${s.activa ? 'Activa' : 'Inactiva'}
        </td>
        <td>
          <a href="/precios?sucursal=${s.slug}" class="action-link" title="Editar precios">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Precios
          </a>
        </td>
      </tr>`
    }).join('')
  }

  document.getElementById('search').addEventListener('input', applyFilters)
  document.getElementById('filter-estado').addEventListener('change', applyFilters)
  document.getElementById('filter-plantilla').addEventListener('change', applyFilters)

  document.getElementById('clear-search').addEventListener('click', () => {
    document.getElementById('search').value = ''
    applyFilters()
  })

  document.getElementById('clear-filters').addEventListener('click', () => {
    document.getElementById('search').value = ''
    document.getElementById('filter-estado').value = ''
    document.getElementById('filter-plantilla').value = ''
    applyFilters()
  })

  init()
</script>
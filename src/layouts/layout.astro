---
import '../styles/global.css'
const { title = "Backoffice" } = Astro.props
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — Carl's Jr. Backoffice</title>
</head>
<body>
  <div class="app-wrapper">
    <nav class="navbar">
      <div class="navbar-left">
        <button class="sidebar-toggle" id="sidebar-toggle" title="Menú">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <img src="/carls-logo.png" alt="Carl's Jr." class="navbar-logo" />
      </div>
      <div class="navbar-right">
        <button class="navbar-user" id="logout-btn" title="Cerrar sesión">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </button>
      </div>
    </nav>

    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <span>MENÚ</span>
        <button id="sidebar-close">✕</button>
      </div>
      <nav class="sidebar-nav">
        <a href="/dashboard" class="sidebar-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
          Dashboard
        </a>
        <a href="/sucursales" class="sidebar-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Sucursales
        </a>
        <a href="/plantillas" class="sidebar-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
          </svg>
          Plantillas
        </a>
      </nav>
    </aside>

    <main class="main-content">
      <slot />
    </main>

    <footer class="app-footer">
      <span>Carl's Jr. Backoffice © 2026. Powered by <strong>ADmira Digital Networks</strong></span>
    </footer>
  </div>

  <script>
    const logoutBtn = document.getElementById('logout-btn')
    if (logoutBtn) {
      logoutBtn.addEventListener('click', async () => {
        const { createClient } = await import('@supabase/supabase-js')
        const db = createClient(
          'https://gbklqpbcllhdixiuxwzt.supabase.co',
          'sb_publishable_478TOeFf5POv09rZ58BeyQ_BA8rY8cf'
        )
        await db.auth.signOut()
        window.location.href = '/'
      })
    }

    const toggle = document.getElementById('sidebar-toggle')
    const close = document.getElementById('sidebar-close')
    const overlay = document.getElementById('sidebar-overlay')
    const sidebar = document.getElementById('sidebar')

    function openSidebar() {
      sidebar.classList.add('open')
      overlay.classList.add('visible')
    }

    function closeSidebar() {
      sidebar.classList.remove('open')
      overlay.classList.remove('visible')
    }

    toggle?.addEventListener('click', openSidebar)
    close?.addEventListener('click', closeSidebar)
    overlay?.addEventListener('click', closeSidebar)
  </script>
</body>
</html>

<style>
.app-wrapper {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-gray);
}

.navbar {
  background: var(--carls-red);
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  flex-shrink: 0;
  box-shadow: 0 2px 6px rgba(0,0,0,0.15);
  position: sticky;
  top: 0;
  z-index: 200;
}

.navbar-left {
  display: flex;
  align-items: center;
  gap: 14px;
}

.navbar-logo {
  height: 32px;
  object-fit: contain;
}

.sidebar-toggle {
  background: none;
  border: none;
  color: white;
  cursor: pointer;
  padding: 6px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
}

.sidebar-toggle:hover {
  background: rgba(255,255,255,0.2);
}

.navbar-user {
  background: none;
  border: none;
  color: white;
  cursor: pointer;
  padding: 6px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
}

.navbar-user:hover {
  background: rgba(255,255,255,0.2);
}

.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 299;
}

.sidebar-overlay.visible {
  display: block;
}

.sidebar {
  position: fixed;
  top: 0;
  left: -260px;
  width: 240px;
  height: 100vh;
  background: white;
  box-shadow: 4px 0 16px rgba(0,0,0,0.12);
  z-index: 300;
  transition: left 0.25s ease;
  display: flex;
  flex-direction: column;
}

.sidebar.open {
  left: 0;
}

.sidebar-header {
  background: var(--carls-red);
  color: white;
  padding: 16px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 52px;
  flex-shrink: 0;
}

.sidebar-header span {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.1em;
}

.sidebar-header button {
  background: none;
  border: none;
  color: white;
  cursor: pointer;
  font-size: 14px;
  padding: 2px 6px;
  border-radius: 4px;
  transition: background 0.15s;
}

.sidebar-header button:hover {
  background: rgba(255,255,255,0.2);
}

.sidebar-nav {
  display: flex;
  flex-direction: column;
  padding: 8px 0;
}

.sidebar-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 11px 20px;
  color: var(--text-dark);
  text-decoration: none;
  font-size: 13px;
  font-weight: 600;
  transition: background 0.15s, color 0.15s;
  border-left: 3px solid transparent;
}

.sidebar-item:hover {
  background: rgba(237,28,36,0.06);
  color: var(--carls-red);
  border-left-color: var(--carls-red);
}

.main-content {
  flex: 1;
  padding: 24px;
  min-width: 0;
}

.app-footer {
  background: var(--carls-red);
  color: rgba(255,255,255,0.9);
  text-align: center;
  padding: 10px;
  font-size: 12px;
  flex-shrink: 0;
}
</style>